@page
@model dynamic
@{
    ViewData["Title"] = "Domains";
}
<section class="page-header">
    <h1>Governance Across Domains</h1>
    <p>One engine, many instantiations: defense, banking, AI, corporate, IT, public sector, and beyond.</p>
</section>

<section class="domain-grid">
    <article class="card">
        <h2>Defense Governance</h2>
        <p>COR enforces mission‑grade governance with executable chains of command, rules of engagement, and secure audit trails. Every decision is traceable, authorized, and aligned with operational doctrine.</p>
    </article>
    <article class="card">
        <h2>Banking & Financial Governance</h2>
        <p>COR transforms regulatory frameworks into executable governance logic, enabling automated compliance, risk scoring, and audit‑ready oversight across financial operations.</p>
    </article>
    <article class="card">
        <h2>AI & Algorithmic Governance</h2>
        <p>Define guardrails for AI systems, including approvals, monitoring, and intervention points for automated decisions.</p>
    </article>
    <article class="card">
        <h2>Corporate & Board Governance</h2>
        <p>Structure board decisions, approvals, and accountability with clear roles and documented processes.</p>
    </article>
    <article class="card">
        <h2>IT & Infrastructure Governance</h2>
        <p>Control changes, access, and configurations through governed workflows and policy‑driven enforcement.</p>
    </article>
    <article class="card">
        <h2>Public Sector Governance</h2>
        <p>Translate public policy and regulatory mandates into executable governance structures with transparency for stakeholders.</p>
    </article>
</section>
