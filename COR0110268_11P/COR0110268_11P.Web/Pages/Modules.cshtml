@page
@model dynamic
@{
    ViewData["Title"] = "Modules";
}
<section class="page-header">
    <h1>Modules & Capabilities</h1>
    <p>Composable governance modules that can be combined and specialized for any domain.</p>
</section>

<section class="card-grid">
    <article class="card">
        <h2>Policy Automation Module</h2>
        <p>Convert governance rules into executable logic with versioning, testing, and controlled rollout.</p>
    </article>
    <article class="card">
        <h2>Decision Governance Module</h2>
        <p>Define who decides what, under which conditions, and with which escalation paths.</p>
    </article>
    <article class="card">
        <h2>Risk & Compliance Module</h2>
        <p>Score risk, detect violations, and trigger alerts or automated responses when governance is breached.</p>
    </article>
    <article class="card">
        <h2>Audit & Traceability Module</h2>
        <p>Maintain immutable logs of decisions, inputs, and rule evaluations for internal and external audits.</p>
    </article>
    <article class="card">
        <h2>Workflow Enforcement Module</h2>
        <p>Ensure processes follow approved governance paths, with guardrails and checkpoints.</p>
    </article>
    <article class="card">
        <h2>Integration Module</h2>
        <p>Connect to existing systems, data sources, and interfaces via APIs and adapters.</p>
    </article>
</section>
